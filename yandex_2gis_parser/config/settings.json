{
  "cities": [
    {
      "name": "Москва",
      "priority": 1,
      "enabled": true,
      "search_queries": ["рестораны"]
    }
  ],
  "sources": {
    "yandex_maps": {
      "enabled": true,
      "priority": 1,
      "fields": ["name", "address", "rating", "reviews_count", "phone", "website", "category"]
    },
    "gis_2": {
      "enabled": false,
      "priority": 2,
      "fields": ["name", "address", "rating", "reviews_count", "phone", "website", "category", "hours"]
    }
  },
  "parsing_settings": {
    "max_objects_per_query": 10,
    "delay_between_actions_min": 3,
    "delay_between_actions_max": 6,
    "scroll_pause_min": 2,
    "scroll_pause_max": 4,
    "mouse_movement_enabled": true,
    "random_scroll_enabled": true,
    "headless_mode": false,
    "proxy_enabled": false,
    "proxy_list": []
  },
  "output": {
    "format": "xlsx",
    "filename_pattern": "{city}_{source}_{date}.xlsx",
    "save_path": "./output"
  }
}
